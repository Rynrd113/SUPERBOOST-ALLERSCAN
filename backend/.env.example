# ============================================================
# SuperBoost AllerScan — Konfigurasi Environment
# Salin file ini ke .env dan isi nilainya
# JANGAN commit file .env ke GitHub!
# ============================================================

# Database MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=allerscan_user
MYSQL_PASSWORD=ganti_dengan_password_anda
MYSQL_DATABASE=allerscan_db

# Aplikasi
ENVIRONMENT=production
DEBUG=false

# CORS — domain frontend produksi (format JSON array)
ALLOW_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]
